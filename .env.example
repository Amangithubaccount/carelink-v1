# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# APPWRITE CONNECTION VARIABLES (For medical dispatch & live notifications persistence)
# Appwrite Project Endpoint (e.g. https://cloud.appwrite.io/v1)
VITE_APPWRITE_ENDPOINT="https://cloud.appwrite.io/v1"
# Appwrite Project ID (from Appwrite console overview)
VITE_APPWRITE_PROJECT_ID=""
# Appwrite Database ID
VITE_APPWRITE_DATABASE_ID="carelink"
# Appwrite Collection ID for incident cases
VITE_APPWRITE_CASES_COLLECTION_ID="cases"
# Appwrite Collection ID for emergency dispatch alerts and live notifications
VITE_APPWRITE_ALERTS_COLLECTION_ID="alerts"

# GOOGLE MAPS PLATFORM KEY
# Required to fetch nearby hospitals and render live interactive maps.
GOOGLE_MAPS_PLATFORM_KEY="YOUR_GOOGLE_MAPS_API_KEY"

